{
  "manifest_version": 3,
  "name": "DHIS2 AI Assistant",
  "version": "2.1.7",
  "description": "AI-powered analytics assistant for DHIS2. Runs on a local Ollama model by default; supports OpenAI, Anthropic, Fireworks, Google, OpenRouter, Together, Groq, and any OpenAI-compatible endpoint.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "webNavigation",
    "scripting",
    "debugger"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "DHIS2 AI Assistant"
  }
}
