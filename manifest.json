{
  "manifest_version": 3,
  "name": "DHIS2 AI Assistant",
  "version": "2.9.0",
  "description": "AI analytics assistant for DHIS2. Runs locally on Ollama by default, or connects to any OpenAI-compatible AI endpoint.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "webNavigation",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/panel.html"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "DHIS2 AI Assistant"
  }
}
